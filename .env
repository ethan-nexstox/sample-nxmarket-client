# OAuth2 Configuration
# ====================

# OAuth2 Authorization Endpoint - where users are redirected to login
NEXT_PUBLIC_OAUTH2_AUTHORIZATION_URL=http://localhost:3072

# OAuth2 Token Endpoint - where authorization codes are exchanged for tokens
NEXT_PUBLIC_OAUTH2_TOKEN_ENDPOINT=http://localhost:3072/oauth2/token

# OAuth2 Client ID - your application's client identifier
NEXT_PUBLIC_OAUTH2_CLIENT_ID=nxmarket-client-web
NEXT_PUBLIC_OAUTH2_CLIENT_SECRET=secret-pkce

# OAuth2 Redirect URI - must match what's registered with your OAuth2 server
# For local development: http://localhost:3074/login/oauth2-code
# For GitHub Pages: https://<username>.github.io/<repo-name>/login/oauth2-code/
NEXT_PUBLIC_OAUTH2_REDIRECT_URI=http://localhost:3074/login/oauth2-code
NEXT_PUBLIC_OAUTH2_POST_LOGOUT_REDIRECT_URI=http://localhost:3074?logged_out=true

# OAuth2 Scopes - space-separated list of requested permissions
NEXT_PUBLIC_OAUTH2_SCOPE=openid profile api.exchange api.user

# Resource Server API
# ====================

# NXMarket API base URL - for fetching user profile and other API calls
NEXT_PUBLIC_NXMARKET_API=http://localhost:8082
